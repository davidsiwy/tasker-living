# Copy this file to .env and fill in from your Supabase project
# (Project settings, API). Leave empty to run the app in demo mode.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Tasker platform API for service ordering and payment (optional)
VITE_TASKER_API_URL=
# Stripe (card payments) is planned, keys will go here when enabled
# VITE_STRIPE_PUBLISHABLE_KEY=

# Delivery API for email, SMS and push reminders (optional; Edge Function)
VITE_NOTIFY_API_URL=
